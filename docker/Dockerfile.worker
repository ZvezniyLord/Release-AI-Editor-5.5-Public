FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

COPY docker/requirements-worker.txt /app/requirements-worker.txt
RUN pip install --no-cache-dir -r /app/requirements-worker.txt

COPY journal_factory /app/journal_factory
COPY schemas /app/schemas
COPY skills /app/skills

RUN python -m compileall -q /app/journal_factory

ENTRYPOINT ["python", "-m", "journal_factory.llm.host_runner"]
