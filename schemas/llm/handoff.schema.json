{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/journal-factory/handoff.schema.json",
  "title": "Journal Factory public handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cycle",
    "status",
    "base_sha",
    "implementation_commit_sha",
    "report_commit_sha",
    "test_records",
    "report_paths",
    "model_config_summary",
    "artifact_data_classes",
    "blockers"
  ],
  "properties": {
    "cycle": {"type": "string", "minLength": 1},
    "status": {"enum": ["COMPLETED", "REVIEW", "BLOCKED", "FAILED"]},
    "base_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "implementation_commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "report_commit_sha": {
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{40}$"
    },
    "test_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "command", "result"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "command": {"type": "string", "minLength": 1},
          "result": {"enum": ["PASS", "FAIL", "BLOCKED", "NOT_RUN"]},
          "notes": {"type": "string"}
        }
      }
    },
    "report_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "handoff", "test_results", "artifact_manifest", "defects"],
      "properties": {
        "summary": {"type": "string", "minLength": 1},
        "handoff": {"type": "string", "minLength": 1},
        "test_results": {"type": "string", "minLength": 1},
        "artifact_manifest": {"type": "string", "minLength": 1},
        "defects": {"type": "string", "minLength": 1},
        "checksums": {"type": "string", "minLength": 1}
      }
    },
    "model_config_summary": {
      "type": "object",
      "additionalProperties": true
    },
    "artifact_data_classes": {
      "type": "array",
      "items": {
        "enum": [
          "public_code",
          "public_docs",
          "sanitized_reports",
          "synthetic_fixtures",
          "docker_config"
        ]
      }
    },
    "blockers": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
