{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/journal-factory/paragraph_classifier_input.v1_1.schema.json",
  "title": "Journal Factory paragraph classifier input v1.1 candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "article_id",
    "source_hash",
    "language",
    "state",
    "source_paragraphs",
    "context_paragraphs",
    "source_id_contract"
  ],
  "properties": {
    "contract_version": {"const": "paragraph_classifier_input.v1.1-candidate"},
    "article_id": {"type": "string", "minLength": 1},
    "source_hash": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
    "language": {"type": "string", "minLength": 2},
    "state": {"$ref": "paragraph_classifier_input.v1.schema.json#/$defs/state"},
    "schema_id": {"type": "string"},
    "source_paragraphs": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/paragraph"}
    },
    "context_paragraphs": {
      "type": "array",
      "items": {"$ref": "#/$defs/paragraph"}
    },
    "source_id_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required_source_ids", "forbidden_context_ids"],
      "properties": {
        "required_source_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "forbidden_context_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "deterministic_markers": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "paragraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paragraph_id", "text"],
      "properties": {
        "paragraph_id": {"type": "string", "minLength": 1},
        "text": {"type": "string"},
        "style_id": {"type": ["string", "null"]},
        "is_empty": {"type": "boolean"}
      }
    }
  }
}
